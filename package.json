{
  "name": "pocketwatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:backup": "pg_dump pocketwatch > backups/pocketwatch-$(date +%Y%m%d-%H%M%S).sql && echo 'Backup saved to backups/'",
    "db:prepare": "npm run db:backup 2>/dev/null; prisma generate && (prisma migrate deploy || prisma db push)",
    "dev": "npm run db:prepare && next dev --hostname 0.0.0.0 --port 3500",
    "build": "if [ -n \"$DATABASE_MIGRATE_URL\" ]; then prisma db push --accept-data-loss --url \"$DATABASE_MIGRATE_URL\"; fi && prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "npm run db:prepare && next start",
    "lint": "eslint",
    "compile": "hardhat compile",
    "compile:force": "hardhat compile --force",
    "test": "hardhat test",
    "test:unit": "npx tsx --test test/**/*.test.ts",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:sepolia": "hardhat run scripts/deploy-vesting.ts --network sepolia",
    "deploy:arbitrum-sepolia": "hardhat run scripts/deploy-vesting.ts --network arbitrumSepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy-vesting.ts --network baseSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy-vesting.ts --network mainnet",
    "verify:sepolia": "hardhat verify --network sepolia",
    "setup:campaign": "hardhat run scripts/setup-campaign.ts",
    "node": "hardhat node",
    "console": "hardhat console",
    "clean": "hardhat clean"
  },
  "dependencies": {
    "@codex-data/sdk": "^2.0.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@grammyjs/auto-retry": "^2.0.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reown/appkit": "^1.8.17",
    "@reown/appkit-adapter-wagmi": "^1.8.17",
    "@tanstack/react-query": "^5.90.20",
    "@types/leaflet": "^1.9.21",
    "@types/react-grid-layout": "^1.3.6",
    "bcryptjs": "^3.0.3",
    "ccxt": "^4.5.40",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "emoji-mart": "^5.6.0",
    "facehash": "^0.1.0",
    "googleapis": "^170.1.0",
    "grammy": "^1.40.0",
    "graphql": "^16.13.0",
    "leaflet": "^1.9.4",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.5",
    "next": "16.1.6",
    "pg": "^8.17.2",
    "plaid": "^41.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-leaflet": "^5.0.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.7.0",
    "socks-proxy-agent": "^9.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "torph": "^0.0.5",
    "viem": "^2.45.0",
    "wagmi": "^2.19.5",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@tailwindcss/postcss": "^4",
    "@typechain/hardhat": "^9.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "hardhat": "^2.28.4",
    "hardhat-gas-reporter": "^2.3.0",
    "prisma": "^7.3.0",
    "solidity-coverage": "^0.8.17",
    "tailwindcss": "^4",
    "typechain": "^8.3.2",
    "typescript": "5.9.3"
  }
}
