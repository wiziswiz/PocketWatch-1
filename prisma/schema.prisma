  tickerSymbol           String?
  isCashEquivalent       Boolean   @default(false)
  type                   String?
  closePrice             Float?
  closePriceAsOf         DateTime?
  isoCurrencyCode        String?
  unofficialCurrencyCode String?
  marketIdentifierCode   String?
  sector                 String?
  industry               String?
  optionContract         Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
