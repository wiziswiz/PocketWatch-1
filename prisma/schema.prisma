model FinanceInvestmentHoldingSnapshot {
  id               String   @id @default(cuid())
  userId           String
  accountId        String
  securityId       String?
  date             DateTime @db.Date
  quantity         Float?
  institutionPrice Float?
  institutionValue Float?
  costBasis        Float?
