model FinanceInvestmentTransaction {
  id                      String   @id @default(cuid())
  userId                  String
  accountId               String
  securityId              String?
  investmentTransactionId String
  date                    DateTime @db.Date
  name                    String
  quantity                Float?
  amount                  Float
  price                   Float?
  fees                    Float?
  type                    String
  subtype                 String?
  isoCurrencyCode         String?
  unofficialCurrencyCode  String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, investmentTransactionId])
  @@index([userId, date])
  @@index([userId, accountId])
}

model FinanceRecurringStream {
  id                      String    @id @default(cuid())
  userId                  String
  streamId                String
  accountId               String
  category                String?
  description             String
  merchantName            String?
  firstDate               DateTime?
  lastDate                DateTime?
  frequency               String
  averageAmount           Float?
  lastAmount              Float?
  isActive                Boolean   @default(true)
  status                  String
  personalFinanceCategory Json?
  streamType              String
  transactionIds          String[]  @default([])
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, streamId])
  @@index([userId])
  @@index([userId, streamType])
}

model ProjectedChartCache {
  id                String   @id @default(cuid())
  userId            String
  timestamp         Int
  value             Float
  walletFingerprint String
  computedAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timestamp, walletFingerprint])
  @@index([userId, walletFingerprint])
}

model PlaidSyncJob {
  id                   String    @id @default(cuid())
  userId               String
  institutionId        String
  jobType              String    // "full_history" | "incremental_sync" | "product_sync"
  status               String    @default("queued") // "queued" | "running" | "completed" | "failed"
  attempt              Int       @default(0)
  maxAttempts          Int       @default(3)
  transactionsFetched  Int       @default(0)
  transactionsInserted Int       @default(0)
  error                String?
  startedAt            DateTime?
  completedAt          DateTime?
  nextRetryAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, nextRetryAt])
  @@index([userId, institutionId, jobType])
}
