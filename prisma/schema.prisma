  @@unique([userId, accountId, securityId, date])
  @@index([userId, date])
  @@index([userId, accountId, date])
}

model FinanceInvestmentSecurity {
  id                     String    @id @default(cuid())
  userId                 String
  securityId             String
  isin                   String?
  cusip                  String?
  sedol                  String?
  institutionSecurityId  String?
  institutionId          String?
  proxySecurityId        String?
