# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# database backups
/backups

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local
pocketwatch-forms-*.json
*.production.local

# Hardhat
cache/
artifacts/
typechain-types/

# Hardhat deployment files
deployments/
/campaigns/

# Compilation artifacts
*.log
gas-report.txt
/coverage/
coverage.json

# Don't commit private keys
*.key
*.private

# Keep example env files
!.env.example
!.env.vesting.example
.next 2/
prisma/dev.db
tmp_*.ts
