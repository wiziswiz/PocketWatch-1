# Database (PostgreSQL — Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:pass@host:5432/pocketwatch"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host:5432/pocketwatch"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encryption key for API keys stored in DB (32-byte hex string)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Zerion API (portfolio balance aggregation)
# Get at: https://zerion.io/developers
ZERION_API_KEY=""

# CoinGecko API (token prices)
COINGECKO_API_KEY=""

# Helius API (Solana RPC, tx history, token metadata)
# Get at: https://dev.helius.xyz
HELIUS_API_KEY=""

# Alchemy (EVM RPC provider)
ALCHEMY_API_KEY=""

# WalletConnect project ID (wallet connection)
# Get at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Internal staking snapshot cron auth secret (required for /api/internal/staking/snapshot-hourly)
STAKING_CRON_SECRET=""

# Internal history sync worker auth secret (required for /api/internal/history/sync-worker)
HISTORY_CRON_SECRET=""

# Internal portfolio refresh worker auth secret (required for /api/internal/portfolio/refresh-worker)
PORTFOLIO_REFRESH_CRON_SECRET=""

# Snapshot worker + transaction classifier auth secret (required for /api/internal/snapshot-worker and /api/internal/classify-transactions)
SNAPSHOT_WORKER_SECRET=""

# Portfolio refresh + provider governor (correctness-first defaults)
PORTFOLIO_REFRESH_TTL_MS="300000"
ZERION_MIN_INTERVAL_MS="20000"
ALCHEMY_MIN_INTERVAL_MS="500"
CCXT_MIN_INTERVAL_MS="15000"
DEFI_LLAMA_MIN_INTERVAL_MS="1000"
PROVIDER_429_BACKOFF_BASE_MS="60000"
PROVIDER_429_BACKOFF_MAX_MS="900000"
